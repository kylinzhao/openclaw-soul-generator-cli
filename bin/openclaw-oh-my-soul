#!/usr/bin/env node
import('../dist/cli.js')
  .then(async ({ runCli }) => {
    const result = await runCli(process.argv.slice(2))

    if (result.output) {
      console.log(result.output)
    }

    process.exitCode = result.exitCode
  })
  .catch((error) => {
    console.error(error instanceof Error ? error.message : String(error))
    process.exitCode = 1
  })
